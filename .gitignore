################################
# Chrome Browser Profile
################################

# Large binary cache and metric files
*.pma
BrowserMetrics-spare.pma
BrowserMetrics.pma

# GPU and Shader caches (large binary files)
GraphiteDawnCache/
GrShaderCache/
ShaderCache/
component_crx_cache/
extensions_crx_cache/

# Chrome HTTP cache (large binary files)
Default/Cache/
Default/Code Cache/

# Database files and journals
*.db
*.db-journal
first_party_sets.db*

# Chrome storage directories
Default/Session Storage/
Default/IndexedDB/
Default/Local Storage/
Default/Sync Data/
Default/GCM Store/
Default/Feature Engagement Tracker/

# Chrome database directories
Default/Affiliation Database*/
Default/AutofillStrikeDatabase/
Default/AutofillAiModelCache/
Default/BudgetDatabase/
Default/Site Characteristics Database/
Default/Extension Scripts/
Default/Extension Rules/
Default/Extension State/
Default/shared_proto_db/

# Chrome state files
Default/heavy_ad_intervention_opt_out.db
Default/Network Action Predictor*

# LevelDB transaction and lock files
*.log
**/000*.log
LOCK
*.log.old

# Journal and temporary files
*-journal
*-lock

# Safe Browsing cache
Safe Browsing/

# Variation data
Variations

# Local browser state
Local State
Last Version

